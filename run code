// =========================
// ===== MODBUS REGISTER MAP =
// Holding Registers (FC03 / FC06)
//
// Sensor i  base = i * 6
//   +0 = Voltage Hi    +1 = Voltage Lo
//   +2 = Current Hi    +3 = Current Lo
//   +4 = Power Hi      +5 = Power Lo
//
// i=0 Solar1  → reg  0– 5
// i=1 Solar2  → reg  6–11
// i=2 Solar3  → reg 12–17
// i=3 Solar4  → reg 18–23
// i=4 LED1    → reg 24–29
// i=5 LED2    → reg 30–35
// i=6 LED3    → reg 36–41
// i=7 LED4    → reg 42–47
// i=8 Battery → reg 48–53
// LUX         → reg 54–55
//
// Special control registers (FC06 write from PC):
// reg 60 = Page switch (PC writes 0-5 → ESP switches DWIN page)
// reg 61 = Poll enable (PC writes 0 = pause, 1 = resume)
// =========================
uint16_t holdingRegs[70] = {0};

// =========================
// ======= LUX COMMAND ======
// =========================
static const uint8_t LuxCmd[8] = { 0x48, 0x03, 0x00, 0x02, 0x00, 0x02, 0x6B, 0x92 };
float LUX = 0.0f;

// =========================
// ======= MUTEX ============
// =========================
SemaphoreHandle_t gLock = nullptr;

